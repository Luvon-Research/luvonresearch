# ┌──────────────────────────────┐
# │ 1) Build your Vite/Vue app  │
# └──────────────────────────────┘
FROM node:18-alpine AS builder

# 1.1 Set working dir inside builder
WORKDIR /app

# 1.2 Copy only package files and install deps (cache layer)
COPY client/package.json client/package-lock.json ./
RUN npm ci

# 1.3 Copy the rest of your client code
COPY client/ .

# 1.4 Build for production
RUN npm run build

# ┌───────────────────────────┐
# │ 2) Serve with nginx✅     │
# └───────────────────────────┘
FROM nginx:alpine

# 2.1 Overwrite default nginx site config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# 2.2 Copy the built static assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# 2.3 Expose port (optional)
EXPOSE 80

# 2.4 Run nginx in foreground
CMD ["nginx", "-g", "daemon off;"]
