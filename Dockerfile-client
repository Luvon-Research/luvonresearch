# ─── BUILD STAGE ──────────────────────────────────────────────────────────────
FROM node:lts-alpine AS build-stage
WORKDIR /app

# Bake VITE_… vars into the Vite build
ARG VITE_CLERK_PUBLISHABLE_KEY
ARG VITE_API_URL
ARG VITE_YJS_SERVER_URL
ENV VITE_CLERK_PUBLISHABLE_KEY=${VITE_CLERK_PUBLISHABLE_KEY}
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_YJS_SERVER_URL=${VITE_YJS_SERVER_URL}

# Install dependencies & build
COPY client/package*.json ./
RUN npm install 
COPY client/ .
RUN npm run build

# ─── PRODUCTION STAGE ─────────────────────────────────────────────────────────
FROM nginx:stable-alpine AS production-stage

# Needed so nginx can do HTTPS proxy_pass
RUN apk add --no-cache ca-certificates

# Use our custom nginx config (listens on 8080, proxies /api/)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built Vue artifacts
COPY --from=build-stage /app/dist /usr/share/nginx/html

# Cloud Run (and many other platforms) route on $PORT=8080
EXPOSE 8080

# Launch nginx in foreground
CMD ["nginx", "-g", "daemon off;"]

